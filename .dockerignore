# ---------- Ignore everything except pom.xml ----------
**/*
!pom.xml

# ---------- Ignore IDE / editor files ----------
*.iml
*.ipr
*.iws
.idea/
*.vscode/
*.classpath
*.project
.settings/

# ---------- Ignore Git ----------
.git
.gitignore

# ---------- Ignore OS / temp files ----------
.DS_Store
Thumbs.db
*.log
tmp/
*.tmp

# ---------- Ignore Docker / environment files ----------
Dockerfile
docker-compose.yml
.env

# ---------- Ignore build artifacts ----------
target/
build/